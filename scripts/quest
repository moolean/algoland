#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
STATE_DIR="$ROOT/.state"
LANG_FILE="$STATE_DIR/lang.env"
PLAYER_DIR="$ROOT/player"
CURRENT_DIR="$PLAYER_DIR/current"
mkdir -p "$STATE_DIR" "$PLAYER_DIR" "$ROOT/submissions"

LEVELS=(L0 L1 L2 L3 L4 L5)

load_lang(){
  if [[ -f "$LANG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$LANG_FILE"
  fi
  ALGOLAND_LANG="${ALGOLAND_LANG:-en}"
}

save_lang(){
  cat > "$LANG_FILE" <<EOF
ALGOLAND_LANG=$ALGOLAND_LANG
EOF
}

tr_text(){
  local zh="$1" en="$2"
  if [[ "$ALGOLAND_LANG" == "zh" ]]; then
    printf "%s" "$zh"
  else
    printf "%s" "$en"
  fi
}

level_title(){
  case "$1" in
    L0) tr_text "Vim 新生训练营" "Vim Boot Sequence" ;;
    L1) tr_text "数据考古学家（Terminal + Git）" "Data Archaeologist (Terminal + Git)" ;;
    L2) tr_text "环境炼金术（Python venv）" "Environment Alchemy (Python venv)" ;;
    L3) tr_text "午夜排障（PDB Debug）" "Midnight Debugging (PDB)" ;;
    L4) tr_text "安全隧道员（SSH）" "SSH Tunnel Basics" ;;
    L5) tr_text "双模型调度官（API）" "LLM API Playground" ;;
  esac
}

level_path(){
  case "$1" in
    L0) echo "$ROOT/levels/L0_vim" ;;
    L1) echo "$ROOT/levels/L1_git_terminal" ;;
    L2) echo "$ROOT/levels/L2_python_env" ;;
    L3) echo "$ROOT/levels/L3_pdb_debug" ;;
    L4) echo "$ROOT/levels/L4_ssh" ;;
    L5) echo "$ROOT/levels/L5_model_api" ;;
    *) return 1 ;;
  esac
}

use_color(){ [[ -t 1 ]] && [[ -n "${TERM:-}" ]] && [[ "${TERM:-}" != "dumb" ]]; }
C0='' C1='' C2='' C3='' C4='' C5='' C6=''
if use_color; then
  C0=$'\033[0m'; C1=$'\033[1;36m'; C2=$'\033[1;35m'; C3=$'\033[1;33m'; C4=$'\033[1;32m'; C5=$'\033[1;31m'; C6=$'\033[38;5;245m'
fi

clear_screen(){ if use_color; then clear || true; fi; }
hr(){ printf "%s━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━%s\n" "$C6" "$C0"; }
soft_hr(){ printf "%s──────────────────────────────────────────────────────────────%s\n" "$C6" "$C0"; }

banner(){
  printf "%s╔════════════════════════════════════════════════════════════╗%s\n" "$C1" "$C0"
  if [[ "$ALGOLAND_LANG" == "zh" ]]; then
    printf "%s║%s  ALGOLAND · 可玩的终端入门世界                     %s║%s\n" "$C1" "$C2" "$C1" "$C0"
    printf "%s║%s  边玩边学 · Patch, Debug, Submit                    %s║%s\n" "$C1" "$C2" "$C1" "$C0"
  else
    printf "%s║%s  ALGOLAND · Playable Terminal Onboarding             %s║%s\n" "$C1" "$C2" "$C1" "$C0"
    printf "%s║%s  Learn by Playing · Patch, Debug, Submit            %s║%s\n" "$C1" "$C2" "$C1" "$C0"
  fi
  printf "%s╚════════════════════════════════════════════════════════════╝%s\n" "$C1" "$C0"
}

pill(){
  local label="$1" value="$2"
  printf "%s[%s]%s %s\n" "$C3" "$label" "$C0" "$value"
}

info_card(){
  local title="$1" body
  shift
  body=$(printf "%b" "$*")
  printf "%s┌─ %s ─%s\n" "$C1" "$title" "$C0"
  while IFS= read -r line; do
    printf "%s│%s %s\n" "$C1" "$C0" "$line"
  done <<< "$body"
  printf "%s└────────────────────────────────────────────────────────────%s\n" "$C1" "$C0"
}

progress_bar(){
  local cur="$1" total="$2" width=24 fill empty
  (( total < 1 )) && total=1
  fill=$(( cur * width / total ))
  empty=$(( width - fill ))
  printf "["
  if (( fill > 0 )); then printf "%0.s█" $(seq 1 "$fill"); fi
  if (( empty > 0 )); then printf "%0.s·" $(seq 1 "$empty"); fi
  printf "] %s/%s" "$cur" "$total"
}

load_state(){
  load_lang
  if [[ -f "$STATE_DIR/progress.env" ]]; then
    # shellcheck disable=SC1090
    source "$STATE_DIR/progress.env"
  else
    LEVEL_INDEX=0
    STEP=1
  fi
}

save_state(){
  cat > "$STATE_DIR/progress.env" <<EOF
LEVEL_INDEX=$LEVEL_INDEX
STEP=$STEP
EOF
  save_lang
}

current_level(){ echo "${LEVELS[$LEVEL_INDEX]}"; }

total_steps(){
  local lv="$1" lp
  lp="$(level_path "$lv")"
  find "$lp/tutorial" -maxdepth 1 -type f -name 'step*.md' | wc -l | tr -d ' '
}

overall_done_count(){
  local idx done=0
  for idx in "${!LEVELS[@]}"; do
    if [[ $idx -lt $LEVEL_INDEX ]]; then done=$((done+1)); fi
  done
  echo "$done"
}

coach_tip(){
  local lv="$1" step="$2"
  case "$lv:$step" in
    L0:1) tr_text "把终端输出保存到文件，是后面所有任务的基础动作。" "Saving command output to a file is a basic move used again and again later." ;;
    L0:2) tr_text "Vim 不要求你精通，先掌握 i / Esc / :wq。" "You do not need to master Vim yet. Just learn i / Esc / :wq first." ;;
    L1:1) tr_text "先观察日志结构，再决定用什么命令；别一上来就写 awk。" "Inspect the log structure first, then decide what command to use; do not jump into awk immediately." ;;
    L1:2) tr_text "这一步其实是在练“提取→计数→排序”这个通用套路。" "This step is really about the extract -> count -> sort pattern." ;;
    L1:3) tr_text "配置文件修改最怕手滑，改完一定自己 cat 一遍。" "Config edits fail on tiny mistakes; always print the file and check it yourself." ;;
    L1:4) tr_text "小步提交不是形式主义，它会让排错和协作轻松很多。" "Small commits are not bureaucracy; they make debugging and collaboration much easier." ;;
    L2:1) tr_text "venv 的本质：让当前项目和别的项目互不污染。" "The point of venv is isolation: this project should not pollute other projects." ;;
    L2:2) tr_text "很多“跑不起来”其实不是代码问题，是环境或配置问题。" "Many failures are not code failures; they are environment or config failures." ;;
    L2:3) tr_text "freeze 相当于给今天的环境拍一张快照。" "A freeze file is a snapshot of the environment you have today." ;;
    L3:1) tr_text "pdb 的重点不是背命令，而是学会看‘执行现场’。" "PDB is not about memorizing commands; it is about seeing the execution state." ;;
    L3:2) tr_text "修完一定验证，不验证的修复不算修复。" "Always verify after a fix; an unverified fix is not really a fix." ;;
    L3:3) tr_text "会 debug 只是第一层，能讲清楚才是真协作能力。" "Debugging is only layer one; being able to explain the result is real collaboration." ;;
    L4:1) tr_text "密钥登录是工程环境里的基础安全习惯。" "Key-based login is a basic engineering security habit." ;;
    L4:2) tr_text "SSH config 的价值，是把长命令固化成稳定别名。" "SSH config turns a long command into a stable alias." ;;
    L4:3) tr_text "配置写完不算完成，验证生效才算完成。" "Writing config is not the end; verifying it is what finishes the task." ;;
    L5:1) tr_text "一次请求失败很正常，关键是你怎么优雅地重试。" "One failed request is normal; what matters is how you recover and patch the client." ;;
    L5:2) tr_text "工程师不只要‘调通’，还要会比较方案差异。" "Engineers do not only make things work; they also understand provider differences." ;;
    *) tr_text "按 lesson.md 的结构慢慢来：理解 → 动手 → 自检 → 提交。" "Follow the lesson flow: understand -> act -> self-check -> submit." ;;
  esac
}

fail_tip(){
  local lv="$1" step="$2"
  case "$lv:$step" in
    L0:1) tr_text "检查 out/vim_version.txt 是否存在；先单独跑 vim --version 和 head -n 1 看看输出。" "Check whether out/vim_version.txt exists. Try vim --version and head -n 1 separately first." ;;
    L0:2) tr_text "out/hello_vim.txt 要至少两行且包含 vim。注意要保存退出，不是只打开文件。" "out/hello_vim.txt must have at least two lines and include the word vim. Make sure you save before quitting." ;;
    L1:1) tr_text "best_run.txt 需要是原始整行。先 cat lab/experiments.log 看每一列，再决定如何取 val_loss。" "best_run.txt must contain the original full line. Inspect the log columns first, then decide how to extract val_loss." ;;
    L1:2) tr_text "error_top2.txt 必须是前 2 名且按次数倒序。先确认你提取的“错误类型”字段对不对。" "error_top2.txt must contain the top two error types sorted by count descending. Check that you extracted the correct field." ;;
    L1:3) tr_text "out/model_fixed.yaml 里必须精确出现 lr: 0.001 和 batch_size: 32。改完用 cat 自检。" "out/model_fixed.yaml must include lr: 0.001 and batch_size: 32 exactly. Print it and verify." ;;
    L1:4) tr_text "确认分支名是 feat/onboarding-l1；至少 2 次 commit，并且最近提交中包含 L1 complete。" "Make sure the branch is feat/onboarding-l1, there are at least two commits, and one recent message contains L1 complete." ;;
    L2:1) tr_text "检查虚拟环境是否创建在 out/.venv，并确认 which python 指向 .venv。" "Check that the virtual environment is in out/.venv and that which python points to .venv." ;;
    L2:2) tr_text "eval_result.json 需要 status=PASS 且 threshold=0.85。请确认你改的是 out/hparams.yaml，不是原始文件。" "eval_result.json must show status=PASS and threshold=0.85. Make sure you edited out/hparams.yaml, not the source file." ;;
    L2:3) tr_text "pip_freeze.txt 里必须包含 rich==13.7.1 和 PyYAML==6.0.2；freeze 前先确认 venv 已激活。" "pip_freeze.txt must include rich==13.7.1 and PyYAML==6.0.2. Check that the venv is active first." ;;
    L3:1) tr_text "pdb_session.txt 里要看到 (Pdb) 提示符和你输入过的 l / p a / p b。建议用 script 录制会话。" "pdb_session.txt should show the (Pdb) prompt and the inspection commands you ran. Use script to record the session." ;;
    L3:2) tr_text "run_output.txt 必须包含 result=6.0。修复后先自己 python out/pdb_bug_fixed.py 看结果。" "run_output.txt must include the expected result. Run the fixed script yourself before submitting." ;;
    L3:3) tr_text "pdb_notes.md 至少 3 行，明确写出根因、观察、修复。" "Make sure the fixed report script prints the expected best run and score into the final output file." ;;
    L4:1) tr_text "检查 out/.ssh/ 目录下是否同时有 id_ed25519 和 id_ed25519.pub。" "Check that out/.ssh/ contains both id_ed25519 and id_ed25519.pub." ;;
    L4:2) tr_text "config 里 HostName / User / Port / IdentityFile 要完整，且别名必须是 train-node。" "The config must include HostName, User, Port, and IdentityFile, and the alias must be train-node." ;;
    L4:3) tr_text "ssh_summary.txt 需要有 hostname / user / port 三行且值正确；建议先看 ssh_effective.txt。" "login_result.txt should show login ok and alias=train-node. Use the simulated login script with your config." ;;
    L5:1) tr_text "requests_log.jsonl 里要有 official 的重试记录，至少一次失败后成功。别忘了先启动 mock_api。" "Patch api_client.py so both single-call providers work, then run python lab/run_step1.py." ;;
    L5:2) tr_text "补上 selfhost 日志，并在 out/summary.md 明确比较 official 与 selfhost。" "Patch multi-turn, image, and stream support in api_client.py, then run python lab/run_step2.py." ;;
    *) tr_text "回看 lesson.md：先看‘你会用到的命令’，再按‘自检’逐项核对。" "Re-read lesson.md and check the self-check section item by item." ;;
  esac
}

success_fx(){
  printf "%s✨ 验收通过！%s\n" "$C4" "$C0"
}

render_current(){
  local lv="$1" lp tsteps step_file
  lp="$(level_path "$lv")"
  tsteps="$(total_steps "$lv")"
  step_file="$lp/tutorial/step${STEP}.md"
  if [[ "$ALGOLAND_LANG" == "en" && -f "$lp/tutorial_en/step${STEP}.md" ]]; then
    step_file="$lp/tutorial_en/step${STEP}.md"
  fi

  rm -rf "$CURRENT_DIR"
  mkdir -p "$CURRENT_DIR/lab" "$ROOT/submissions/$lv"
  ln -sfn "$ROOT/submissions/$lv" "$CURRENT_DIR/out"

  cat > "$CURRENT_DIR/submit" <<'EOS'
#!/usr/bin/env bash
"$(cd "$(dirname "$0")/../.." && pwd)/scripts/quest" submit
EOS
  cat > "$CURRENT_DIR/status" <<'EOS'
#!/usr/bin/env bash
"$(cd "$(dirname "$0")/../.." && pwd)/scripts/quest" status
EOS
  chmod +x "$CURRENT_DIR/submit" "$CURRENT_DIR/status"

  ln -sfn "$CURRENT_DIR/lab" "$ROOT/lab"
  ln -sfn "$CURRENT_DIR/out" "$ROOT/out"
  ln -sfn "$CURRENT_DIR/lesson.md" "$ROOT/lesson.md"

  case "$lv" in
    L0) : ;;
    L1) cp -R "$ROOT/levels/L1_git_terminal/lab/." "$CURRENT_DIR/lab/" ;;
    L2)
      cp "$ROOT/levels/L2_python_env/requirements.txt" "$CURRENT_DIR/lab/requirements.txt"
      cp "$ROOT/levels/L2_python_env/run_eval.py" "$CURRENT_DIR/lab/run_eval.py"
      cp "$ROOT/levels/L2_python_env/hparams_bad.yaml" "$CURRENT_DIR/lab/hparams_bad.yaml"
      ;;
    L3)
      cp "$ROOT/levels/L3_pdb_debug/lab/pdb_bug.py" "$CURRENT_DIR/lab/pdb_bug.py"
      cp "$ROOT/levels/L3_pdb_debug/lab/score_rows.jsonl" "$CURRENT_DIR/lab/score_rows.jsonl"
      cp "$ROOT/levels/L3_pdb_debug/lab/batch_report_bug.py" "$CURRENT_DIR/lab/batch_report_bug.py"
      cp "$ROOT/levels/L3_pdb_debug/lab/experiment_results.jsonl" "$CURRENT_DIR/lab/experiment_results.jsonl"
      ;;
    L4)
      cp "$ROOT/levels/L4_ssh/lab/mock_ssh_login.sh" "$CURRENT_DIR/lab/mock_ssh_login.sh"
      chmod +x "$CURRENT_DIR/lab/mock_ssh_login.sh"
      ;;
    L5)
      cp "$ROOT/levels/L5_model_api/lab/mock_api.py" "$CURRENT_DIR/lab/mock_api.py"
      cp "$ROOT/levels/L5_model_api/lab/api_client.py" "$CURRENT_DIR/lab/api_client.py"
      cp "$ROOT/levels/L5_model_api/lab/run_step1.py" "$CURRENT_DIR/lab/run_step1.py"
      cp "$ROOT/levels/L5_model_api/lab/run_step2.py" "$CURRENT_DIR/lab/run_step2.py"
      cat > "$CURRENT_DIR/lab/api_state.json" <<'EOF'
{"openai_sync_ok":false,"anthropic_sync_ok":false,"multiturn_ok":false,"image_ok":false,"stream_ok":false,"requests":[]}
EOF
      if [[ -f "$STATE_DIR/l5_api.pid" ]]; then kill "$(cat "$STATE_DIR/l5_api.pid")" 2>/dev/null || true; fi
      nohup python3 "$CURRENT_DIR/lab/mock_api.py" "$CURRENT_DIR/lab/api_state.json" 8765 > "$STATE_DIR/l5_api.log" 2>&1 &
      echo $! > "$STATE_DIR/l5_api.pid"
      sleep 0.3
      ;;
  esac

  cp "$step_file" "$CURRENT_DIR/lesson.md"

  clear_screen
  banner
  pill "关卡" "$lv · $(level_title "$lv")"
  pill "当前步骤" "$(progress_bar "$STEP" "$tsteps")"
  pill "总进度" "$(progress_bar "$(overall_done_count)" "${#LEVELS[@]}")"
  soft_hr
  info_card "教练提示" "$(coach_tip "$lv" "$STEP")"
  printf "\n%s▶ 教学 + 任务%s\n" "$C3" "$C0"
  hr
  cat "$CURRENT_DIR/lesson.md"
  hr
  info_card "本步可直接使用" "lab/      输入材料\nout/      当前步骤产物\nlesson.md 当前教学内容\n./quest submit  提交当前步骤\n./quest status  查看整体进度"
  printf "\n%s你不需要 cd 到别的目录，直接在仓库根目录完成即可。%s\n" "$C4" "$C0"
}

start(){
  load_state
  if [[ ! -f "$STATE_DIR/.first_run_seen" ]]; then
    clear_screen
    banner
    info_card "新手说明（30秒）" "1. 每次只做当前步骤，不要试图一次看完整套题。\n2. 你只需要记两个命令：./start 和 ./quest submit。\n3. 右下角没有神秘机关；卡住就回看 lesson.md。\n4. lab/ 是材料，out/ 是你要交的结果。"
    touch "$STATE_DIR/.first_run_seen"
  fi
  if [[ $LEVEL_INDEX -ge ${#LEVELS[@]} ]]; then
    banner
    printf "\n%s🎉 全部关卡完成！%s\n" "$C4" "$C0"
    status
    exit 0
  fi
  render_current "$(current_level)"
  save_state
}

submit(){
  load_state
  if [[ $LEVEL_INDEX -ge ${#LEVELS[@]} ]]; then
    printf "%s🎉 已通关，无需提交。%s\n" "$C4" "$C0"
    exit 0
  fi

  local lv lp tsteps
  lv="$(current_level)"
  lp="$(level_path "$lv")"
  tsteps="$(total_steps "$lv")"

  printf "\n%s🧪 正在验收：%s Step %s/%s%s\n" "$C3" "$lv" "$STEP" "$tsteps" "$C0"
  if bash "$lp/check_step.sh" "$STEP"; then
    success_fx
    printf "%s✅ Step %s 通过！ +10 XP%s\n" "$C4" "$STEP" "$C0"
    STEP=$((STEP + 1))

    if [[ $STEP -gt $tsteps ]]; then
      printf "%s🏅 %s 通关成功！正在解锁下一关...%s\n" "$C4" "$lv" "$C0"
      LEVEL_INDEX=$((LEVEL_INDEX + 1))
      STEP=1
      if [[ $LEVEL_INDEX -ge ${#LEVELS[@]} ]]; then
        rm -rf "$CURRENT_DIR"
        save_state
        clear_screen
        banner
        info_card "任务完成" "你已完成全部终端闯关训练。\n建议现在执行 ./quest status 回顾所有关卡。"
        status
        exit 0
      fi
    fi

    save_state
    render_current "$(current_level)"
  else
    printf "%s❌ 当前步骤未通过。%s\n" "$C5" "$C0"
    info_card "建议你现在这样检查" "$(fail_tip "$lv" "$STEP")"
    printf "%s📘 回看教学：lesson.md%s\n" "$C3" "$C0"
    save_state
  fi
}

status(){
  local lv lp tsteps done_steps i
  load_state
  clear_screen
  banner
  pill "总进度" "$(progress_bar "$(overall_done_count)" "${#LEVELS[@]}")"
  hr
  for lv in "${LEVELS[@]}"; do
    lp="$(level_path "$lv")"
    tsteps="$(total_steps "$lv")"
    done_steps=0
    for i in $(seq 1 "$tsteps"); do
      [[ -f "$STATE_DIR/${lv}.step${i}.score" ]] && done_steps=$((done_steps+1))
    done
    printf "%s%-3s%s %-26s %s\n" "$C3" "$lv" "$C0" "$(level_title "$lv")" "$(progress_bar "$done_steps" "$tsteps")"
  done
  hr
  if [[ $LEVEL_INDEX -lt ${#LEVELS[@]} ]]; then
    printf "%s当前所在：%s step %s%s\n" "$C4" "$(current_level)" "$STEP" "$C0"
  else
    printf "%s当前所在：已通关%s\n" "$C4" "$C0"
  fi
}

reset(){
  rm -f "$STATE_DIR/progress.env" "$STATE_DIR/.first_run_seen"
  rm -f "$STATE_DIR"/*.step*.score 2>/dev/null || true
  rm -rf "$CURRENT_DIR" "$ROOT/lab" "$ROOT/out" "$ROOT/lesson.md"
  for lv in "${LEVELS[@]}"; do
    rm -rf "$ROOT/submissions/$lv"
    mkdir -p "$ROOT/submissions/$lv"
  done
  printf "%s✅ 进度与提交产物已重置（L0~L5）。%s\n" "$C4" "$C0"
}

sync(){
  load_state
  if [[ $LEVEL_INDEX -ge ${#LEVELS[@]} ]]; then
    return 0
  fi
  render_current "$(current_level)" >/dev/null
  save_state
}

goto_step(){
  local raw_level="${1:-}" raw_step="${2:-1}" level_num=""
  if [[ -z "$raw_level" ]]; then
    echo "用法: ./quest goto <L0|L1|L2|L3|L4|L5|0-5> [step]"
    return 1
  fi

  case "$raw_level" in
    L0|l0|0) level_num=0 ;;
    L1|l1|1) level_num=1 ;;
    L2|l2|2) level_num=2 ;;
    L3|l3|3) level_num=3 ;;
    L4|l4|4) level_num=4 ;;
    L5|l5|5) level_num=5 ;;
    *)
      echo "未知关卡：$raw_level"
      echo "可用：L0~L5 或 0~5"
      return 1
      ;;
  esac

  if ! [[ "$raw_step" =~ ^[0-9]+$ ]] || [[ "$raw_step" -lt 1 ]]; then
    echo "step 必须是正整数"
    return 1
  fi

  LEVEL_INDEX="$level_num"
  STEP="$raw_step"
  save_state
  sync >/dev/null 2>&1 || true
  clear_screen
  banner
  info_card "已跳转" "当前定位到 ${LEVELS[$LEVEL_INDEX]} · step $STEP\n直接运行 ./start 即可进入该步骤。"
}

usage(){
  cat <<USAGE
用法: ./quest <start|submit|status|reset|sync|goto>

快捷跳转：
  ./quest goto L0 1
  ./quest goto L1 2
  ./quest goto 3 1
USAGE
}

case "${1:-}" in
  start) start ;;
  submit) submit ;;
  status) status ;;
  reset) reset ;;
  sync) sync ;;
  goto) shift; goto_step "${1:-}" "${2:-1}" ;;
  *) usage; exit 1 ;;
esac
